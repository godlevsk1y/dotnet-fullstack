<Project>
    <PropertyGroup>
        <!-- Включаем центральное управление версиями -->
        <ManagePackageVersionsCentrally>true</ManagePackageVersionsCentrally>
        <!-- Транзитивные зависимости тоже закрепляются -->
        <CentralPackageTransitivePinningEnabled>true</CentralPackageTransitivePinningEnabled>
    </PropertyGroup>

    <ItemGroup>
        <!-- HTTP / OpenAPI -->
        <PackageVersion Include="Microsoft.AspNetCore.OpenApi" Version="10.0.9" />
        <PackageVersion Include="Scalar.AspNetCore" Version="2.16.4" />

        <!-- Анализаторы (версии здесь, подключение в Directory.Build.props) -->
        <PackageVersion Include="Roslynator.Analyzers" Version="4.15.0" />
        <PackageVersion Include="Meziantou.Analyzer" Version="3.0.109" />
        <PackageVersion Include="AsyncFixer" Version="2.1.0" />
        <PackageVersion Include="SonarAnalyzer.CSharp" Version="10.27.0.140913s" />
    </ItemGroup>
</Project>